# Copy this file to .env.prod on the server, then replace all passwords.

SPRING_PROFILES_ACTIVE=prod

DB_HOST=postgres
DB_PORT=5432
DB_NAME=spring_ddd_template
DB_USERNAME=spring_app
DB_PASSWORD=change-me-postgres-password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_DATABASE=0
REDIS_SSL=false

# Required S3-compatible file storage. Configure all values before starting the application.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PATH_STYLE_ACCESS=false
