# ============================
# 数据库配置（PostgreSQL）
# ============================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=spring_ddd_template
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ============================
# Redis 配置
# ============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
# 云 Redis（如 Upstash）通常强制 TLS，需设为 true
REDIS_SSL=false

# ============================
# S3 兼容对象存储配置（必填，阿里云 OSS / 腾讯云 COS / MinIO）
# ============================
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PATH_STYLE_ACCESS=false
